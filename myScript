tscript() {
    # test script 快速测试脚本
    # 形式: 在 tmux 中打开左右两个窗口，左边是脚本，右边是测试，脚本修改后自动执行
    if ! command -v fswatch &> /dev/null; then
        echo -e "\033[32mfswatch\033[0m should be installed first."
        return
    fi

    local session_name
    local editor_pane
    local fswatch_pane

    if [ -z "$TMUX" ]; then
        # 不在 tmux 里：新建一个 session
        session_name="tscript"
        tmux new-session -s "$session_name" -d
        # 取这个 session 里的第一个 pane 作为编辑 pane
        editor_pane="$(tmux list-panes -t "$session_name" -F '#{pane_id}' | head -n1)"
    else
        # 在 tmux 里：使用当前 session & 当前 pane
        session_name="$(tmux display-message -p '#S')"
        editor_pane="$(tmux display-message -p '#{pane_id}')"
    fi

    local script_file
    if [ -z "$1" ]; then
        script_file="/tmp/$(uuidgen).sh"
        pbpaste > "$script_file"
    else
        script_file="$1"
    fi

    # 在编辑 pane 里打开文件
    tmux send-keys -t "$editor_pane" "$EDITOR \"$script_file\"" C-m

    # 以编辑 pane 为目标水平分屏，拿到新 pane 的 id 作为 fswatch pane
    fswatch_pane="$(tmux split-window -h -t "$editor_pane" -P -F '#{pane_id}')"

    # 在 fswatch pane 里跑自动执行脚本
    tmux send-keys -t "$fswatch_pane" \
        "fswatch -o \"$script_file\" | xargs -n1 -I{} sh -c 'clear; echo \"=====================\"; echo \"\$(date +\"%Y-%m-%d %H:%M:%S\") ==> Running script\"; echo \"=====================\"; sh \"$script_file\"'" \
        C-m

    # 如果一开始不在 tmux，就 attach 上去
    if [ -z "$TMUX" ]; then
        tmux attach -t "$session_name"
    fi
}

# 快速切换 env 文件
envuse() {
    ## Usage
    # envuse <environment>
    #
    # Eg: envuse dev
    #
    ##

    if [ -z "$1" ]; then
        echo "Usage: envuse <environment>"
        return
    fi
    local environment=$1

    # 判断.env.${environment} 是否存在
    if [ ! -f ".env.${environment}" ]; then
        echo "$(ansi --cyan .env.${environment}) not exist."
        return
    fi

    # 判断 .env 是否存在，并且是文件
    if [[ -f ".env" && ! -L ".env" ]]; then
        echo "$(ansi --cyan .env) exists, and it's a file, please remove it first."
        return
    fi


    local env_file=".env.${environment}"
    ln -sf $env_file .env
}

# 本地端口转发
portforward() {
