# 智能连接 tmux，使用当前文件夹名作为 session 名
function tf() {
  local session_name="$(basename "$PWD")"

  # 检查 session 是否存在
  if tmux has-session -t "$session_name" 2>/dev/null; then
      # 存在则创建新的关联会话
      tmux new-session -t "$session_name"
  else
      # 不存在则创建新 session
      tmux new-session -s "$session_name"
  fi
}

function ai-update() {
    typeset -A tools
    tools=(
      gemini-cli  "npm install -g @google/gemini-cli"
      codex       "npm i -g @openai/codex"
      opencode    "npm i -g opencode-ai"
      claude      "claude update|npm install -g @anthropic-ai/claude-code"
    )

    for name in "${(@k)tools}"; do
      echo ">>> Updating $name ..."
      local updated=false
      IFS='|' read -rA cmds <<< "${tools[$name]}"
      for cmd in "${cmds[@]}"; do
        if eval "$cmd"; then
          updated=true
          break
        fi
      done
      [[ $updated == false ]] && echo "WARNING: $name update failed, skipping." >&2
    done
}


