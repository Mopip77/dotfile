# 最小环境变量启动，防止环境变量污染
tmux() {
    env -i \
        HOME="$HOME" \
        TERM="${TERM:-xterm-256color}" \
        USER="$USER" \
        PATH="$PATH" \
        SHELL="$SHELL" \
        LANG="${LANG:-en_US.UTF-8}" \
        ${SSH_AUTH_SOCK:+SSH_AUTH_SOCK="$SSH_AUTH_SOCK"} \
        ${SSH_CONNECTION:+SSH_CONNECTION="$SSH_CONNECTION"} \
        command tmux "$@"
}

